# Only deployment-essential / secret values live in the environment.
# All tuning parameters are in config.yaml (see that file).

# Copy to .env for local runs (or use docker-compose which sets these).

# HTTP listen port (provided by the platform in production)
PORT=8080

# Postgres connection string (required, secret)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/batch?sslmode=disable

# Optional: path to the YAML tuning config (defaults to ./config.yaml)
# CONFIG_PATH=config.yaml
